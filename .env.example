# Copy to .env and fill in real values. Never commit .env.

# Postgres connection string (Neon, Supabase, RDS, etc.)
DATABASE_URL=""

# NextAuth — generate with: npx auth secret
AUTH_SECRET=""
AUTH_TRUST_HOST="true"

# Optional: 3CX live chat integration (leave empty to use the built-in assistant)
NEXT_PUBLIC_CHAT_PROVIDER="klima"
NEXT_PUBLIC_3CX_CHAT_URL=""

# Email sending (Resend — https://resend.com). REQUIRED: without a key,
# verification codes, password resets, and order receipts cannot be sent.
# EMAIL_FROM requires a domain verified in Resend, e.g. "KlimaENG <info@klimaeng.com>"
RESEND_API_KEY=""
EMAIL_FROM=""

# Product image uploads (Vercel Blob — https://vercel.com/docs/storage/vercel-blob).
# REQUIRED in production: the serverless filesystem is read-only, so the
# admin image uploader cannot write to disk there. Create a Blob store in
# the Vercel dashboard (Storage tab) and it auto-populates this var when
# linked with `vercel env pull`; for local dev it's optional (falls back to
# writing into /public/uploads).
BLOB_READ_WRITE_TOKEN=""
