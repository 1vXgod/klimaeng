generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  passwordHash  String
  role          String         @default("CUSTOMER")
  phone         String?
  image         String?
  language      String         @default("sq")
  theme         String         @default("light")
  emailVerified DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  activities    ActivityLog[]
  addresses     Address[]
  notifications Notification[]
  orders        Order[]
  resetTokens   PasswordResetToken[]
}

/// Legacy reset-link tokens — superseded by VerificationCode; kept so the
/// (empty) table is not dropped from the production database.
model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Short-lived 6-digit codes for email verification and password resets.
model VerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  purpose   String // VERIFY_EMAIL | RESET_PASSWORD
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email, purpose])
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  label     String   @default("Shtëpia")
  street    String
  city      String
  zip       String?
  phone     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Product {
  id            String      @id @default(cuid())
  slug          String      @unique
  name          String
  brand         String
  category      String
  price         Int
  oldPrice      Int?
  shortDesc     String
  description   String
  btu           Int?
  coverageM2    Int?
  energyCool    String?
  energyHeat    String?
  seer          Float?
  scop          Float?
  refrigerant   String?
  noiseDb       Int?
  wifi          Boolean     @default(false)
  inverter      Boolean     @default(false)
  warrantyYears Int         @default(2)
  stock         Int         @default(0)
  featured      Boolean     @default(false)
  badge         String?
  render        String      @default("wall")
  accent        String      @default("blue")
  features      String      @default("[]")
  imageUrl      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  orderItems    OrderItem[]
  reviews       Review[]
}

model Review {
  id         String   @id @default(cuid())
  productId  String?
  authorName String
  city       String?
  rating     Int
  text       String
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now())
  product    Product? @relation(fields: [productId], references: [id])
}

model Order {
  id               String      @id @default(cuid())
  orderNo          String      @unique
  userId           String?
  customerName     String
  email            String
  phone            String
  city             String
  street           String
  note             String?
  withInstallation Boolean     @default(true)
  status           String      @default("PENDING")
  total            Int
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  user             User?       @relation(fields: [userId], references: [id])
  items            OrderItem[]
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String?
  name      String
  price     Int
  qty       Int      @default(1)
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String   @default("info")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  actor     String
  action    String
  detail    String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}
